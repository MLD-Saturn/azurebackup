<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AzureBackup.ViewModels"
        xmlns:models="using:AzureBackup.Core.Models"
        x:Class="AzureBackup.Views.PreviewDialog"
        x:DataType="vm:OperationPreviewViewModel"
        Title="{Binding Title}"
        Width="700" Height="550"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Window.Styles>
        <Style Selector="Border.section">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltMediumHighBrush}"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>
        <Style Selector="Expander">
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource SystemAccentColor}" Padding="16">
            <Grid ColumnDefinitions="Auto,*">
                <TextBlock Text="{Binding Icon}" FontSize="32" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding Description}" Foreground="White" Opacity="0.9" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="16">
            <StackPanel Spacing="8">
                <!-- Source/Target Info -->
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="0,0,0,8">
                    <TextBlock Text="From:" FontWeight="SemiBold" Margin="0,0,8,4"/>
                    <TextBlock Grid.Column="1" Text="{Binding Source}" TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding Source}"/>
                    <TextBlock Grid.Row="1" Text="To:" FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Target}" TextTrimming="CharacterEllipsis"
                               ToolTip.Tip="{Binding Target}"/>
                </Grid>

                <!-- Warning Banner -->
                <Border IsVisible="{Binding HasWarning}" Background="#FFF3CD" BorderBrush="#FFC107" 
                        BorderThickness="1" CornerRadius="4" Padding="12">
                    <TextBlock Text="{Binding WarningMessage}" Foreground="#856404" TextWrapping="Wrap"/>
                </Border>

                <!-- Summary Stats -->
                <Border Classes="section">
                    <Grid ColumnDefinitions="*,*,*,*">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Preview.CreateCount}" FontSize="24" FontWeight="Bold" 
                                       Foreground="Green" HorizontalAlignment="Center"/>
                            <TextBlock Text="New" Opacity="0.7" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Preview.OverwriteCount}" FontSize="24" FontWeight="Bold" 
                                       Foreground="Orange" HorizontalAlignment="Center"/>
                            <TextBlock Text="Overwrite" Opacity="0.7" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Preview.DeleteCount}" FontSize="24" FontWeight="Bold" 
                                       Foreground="Red" HorizontalAlignment="Center"/>
                            <TextBlock Text="Delete" Opacity="0.7" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Preview.SkipCount}" FontSize="24" FontWeight="Bold" 
                                       Foreground="Gray" HorizontalAlignment="Center"/>
                            <TextBlock Text="Unchanged" Opacity="0.7" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Transfer/Delete Size -->
                <StackPanel Orientation="Horizontal" Spacing="24" Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Transfer: " Opacity="0.7"/>
                        <TextBlock Text="{Binding TransferSize}" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" IsVisible="{Binding ShowDeleteSection}">
                        <TextBlock Text="Delete: " Opacity="0.7"/>
                        <TextBlock Text="{Binding DeleteSize}" FontWeight="SemiBold" Foreground="Red"/>
                    </StackPanel>
                </StackPanel>

                <!-- Storage Tier Selection (for backup operations) -->
                <Border Classes="section" IsVisible="{Binding IsBackupOperation}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Storage Tier" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <ComboBox ItemsSource="{Binding StorageTierOptions}"
                                      SelectedItem="{Binding SelectedStorageTier}"
                                      MinWidth="120"/>
                            <TextBlock Text="{Binding StorageTierDescription}" VerticalAlignment="Center" Opacity="0.7"/>
                        </StackPanel>
                        <TextBlock Text="Default from watched folder settings can be overridden for this backup."
                                   FontSize="11" Opacity="0.5"/>
                    </StackPanel>
                </Border>

                <!-- Files to Create -->
                <Expander IsVisible="{Binding ShowCreateSection}" IsExpanded="True">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="New:" FontSize="14" Foreground="Green"/>
                            <TextBlock Text="Files to Create" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Preview.CreateCount, StringFormat='({0})'}" Opacity="0.7"/>
                        </StackPanel>
                    </Expander.Header>
                    <Border BorderThickness="1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" 
                            CornerRadius="4" MaxHeight="200">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding FilesToCreate}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,6" BorderThickness="0,0,0,1" 
                                                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
                                            <Grid ColumnDefinitions="2*,80,100,3*">
                                                <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding FilePath}" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding FileSizeText}" Opacity="0.8"/>
                                                <TextBlock Grid.Column="2" Text="{Binding LastModifiedText}" Opacity="0.7" FontSize="11"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Directory}" TextTrimming="CharacterEllipsis"
                                                           Opacity="0.6" FontSize="11" ToolTip.Tip="{Binding Directory}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Expander>

                <!-- Files to Overwrite -->
                <Expander IsVisible="{Binding ShowOverwriteSection}" IsExpanded="True">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Update:" FontSize="14" Foreground="Orange"/>
                            <TextBlock Text="Files to Overwrite" FontWeight="SemiBold" Foreground="Orange"/>
                            <TextBlock Text="{Binding Preview.OverwriteCount, StringFormat='({0})'}" Opacity="0.7"/>
                        </StackPanel>
                    </Expander.Header>
                    <Border BorderThickness="1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" 
                            CornerRadius="4" MaxHeight="200">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding FilesToOverwrite}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,6" BorderThickness="0,0,0,1" 
                                                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
                                            <Grid ColumnDefinitions="2*,80,100,2*">
                                                <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding FilePath}" FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1" Text="{Binding FileSizeText}" Opacity="0.8"/>
                                                <TextBlock Grid.Column="2" Text="{Binding LastModifiedText}" Opacity="0.7" FontSize="11"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Reason}" TextTrimming="CharacterEllipsis"
                                                           Opacity="0.7" Foreground="Orange"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Expander>

                <!-- Files to Delete -->
                <Expander IsVisible="{Binding ShowDeleteSection}" IsExpanded="True">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Delete:" FontSize="14" Foreground="Red"/>
                            <TextBlock Text="Files to Delete" FontWeight="SemiBold" Foreground="Red"/>
                            <TextBlock Text="{Binding Preview.DeleteCount, StringFormat='({0})'}" Opacity="0.7"/>
                        </StackPanel>
                    </Expander.Header>
                    <Border BorderThickness="1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" 
                            CornerRadius="4" MaxHeight="200">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding FilesToDelete}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,6" BorderThickness="0,0,0,1" 
                                                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
                                            <Grid ColumnDefinitions="2*,80,100,2*">
                                                <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding FilePath}" FontWeight="SemiBold" Foreground="Red"/>
                                                <TextBlock Grid.Column="1" Text="{Binding FileSizeText}" Opacity="0.8"/>
                                                <TextBlock Grid.Column="2" Text="{Binding LastModifiedText}" Opacity="0.7" FontSize="11"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Reason}" TextTrimming="CharacterEllipsis"
                                                           Opacity="0.7"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Expander>

                <!-- Files to Skip (collapsed by default) -->
                <Expander IsVisible="{Binding ShowSkipSection}" IsExpanded="False">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Skip:" FontSize="14" Opacity="0.7"/>
                            <TextBlock Text="Files Unchanged (skipping)" FontWeight="SemiBold" Opacity="0.7"/>
                            <TextBlock Text="{Binding Preview.SkipCount, StringFormat='({0})'}" Opacity="0.7"/>
                        </StackPanel>
                    </Expander.Header>
                    <Border BorderThickness="1" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" 
                            CornerRadius="4" MaxHeight="200">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding FilesToSkip}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,6" BorderThickness="0,0,0,1" 
                                                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}">
                                            <Grid ColumnDefinitions="2*,80,100,3*">
                                                <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding FilePath}" Opacity="0.7"/>
                                                <TextBlock Grid.Column="1" Text="{Binding FileSizeText}" Opacity="0.6"/>
                                                <TextBlock Grid.Column="2" Text="{Binding LastModifiedText}" Opacity="0.5" FontSize="11"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Directory}" TextTrimming="CharacterEllipsis"
                                                           Opacity="0.5" FontSize="11" ToolTip.Tip="{Binding Directory}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Expander>

                <!-- No Changes Message -->
                <Border IsVisible="{Binding !HasChanges}" Classes="section">
                    <TextBlock Text="No changes needed - all files are up to date." 
                               HorizontalAlignment="Center" FontStyle="Italic" Opacity="0.7"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" 
                BorderThickness="0,1,0,0" Padding="16">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Text="{Binding Summary}" VerticalAlignment="Center" Opacity="0.7"/>
                
                <Button Grid.Column="1" Content="Cancel" Click="CancelButton_Click" 
                        Margin="0,0,8,0" Padding="16,8"/>
                
                <Button Grid.Column="2" Click="ConfirmButton_Click"
                        IsEnabled="{Binding CanConfirm}" Padding="16,8">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding Icon}"/>
                            <TextBlock Text="{Binding ConfirmButtonText}"/>
                        </StackPanel>
                    </Button.Content>
                    <Button.Styles>
                        <Style Selector="Button">
                            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </Button.Styles>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
