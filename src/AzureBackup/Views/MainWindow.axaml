<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AzureBackup.ViewModels"
        xmlns:views="using:AzureBackup.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="AzureBackup.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}"
        MinWidth="900" MinHeight="600">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Navigation Header -->
        <Border Grid.Row="0" Background="{DynamicResource AppAccentBrush}" Padding="16">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Text="Azure Backup" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                    <Button Content="Sync" Command="{Binding NavigateToCommand}" CommandParameter="Sync" Classes="nav"
                            ToolTip.Tip="View and sync local and Azure files"/>
                    <Button Content="Migration" Command="{Binding NavigateToCommand}" CommandParameter="Migration" Classes="nav"
                            ToolTip.Tip="Move files between storage tiers (Hot, Cool, Cold, Archive)"/>
                    <Button Content="Storage Health" Command="{Binding NavigateToCommand}" CommandParameter="StorageHealth" Classes="nav"
                            ToolTip.Tip="View chunk index and manage orphaned storage"/>
                    <Button Content="Settings" Command="{Binding NavigateToCommand}" CommandParameter="Settings" Classes="nav"
                            ToolTip.Tip="Configure Azure connection and watched folders"/>
                    <Button Content="Logs" Command="{Binding NavigateToCommand}" CommandParameter="Logs" Classes="nav"
                            ToolTip.Tip="View application logs"/>
                    <!-- Progress tab button — only visible during active operations -->
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="Progress" Classes="nav"
                            IsVisible="{Binding ShowProgressNavButton}"
                            ToolTip.Tip="View operation progress">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <!-- Pulsing green dot while operation is active -->
                            <Ellipse Width="8" Height="8" Fill="#4CAF50" Classes="pulse"
                                     IsVisible="{Binding ProgressTab.ShowActiveProgress}"/>
                            <!-- Static blue dot when operation completed (waiting for user Ok) -->
                            <Ellipse Width="8" Height="8" Fill="#2196F3"
                                     IsVisible="{Binding ProgressTab.ShowCompletionSummary}"/>
                            <TextBlock Text="Progress" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Ellipse Width="12" Height="12" Fill="{Binding IsBackupRunning, Converter={StaticResource BoolToColorConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content - View Switching -->
        <Grid Grid.Row="1" Margin="16">
            <!-- Sync View -->
            <views:SyncView IsVisible="False">
                <views:SyncView.IsVisible>
                    <Binding Path="CurrentView">
                        <Binding.Converter>
                            <vm:EqualityConverter CompareValue="Sync"/>
                        </Binding.Converter>
                    </Binding>
                </views:SyncView.IsVisible>
            </views:SyncView>

            <!-- Settings View -->
            <views:SettingsView IsVisible="False">
                <views:SettingsView.IsVisible>
                    <Binding Path="CurrentView">
                        <Binding.Converter>
                            <vm:EqualityConverter CompareValue="Settings"/>
                        </Binding.Converter>
                    </Binding>
                </views:SettingsView.IsVisible>
            </views:SettingsView>

            <!-- Logs View -->
            <views:LogsView IsVisible="False">
                <views:LogsView.IsVisible>
                    <Binding Path="CurrentView">
                        <Binding.Converter>
                            <vm:EqualityConverter CompareValue="Logs"/>
                        </Binding.Converter>
                    </Binding>
                </views:LogsView.IsVisible>
            </views:LogsView>

            <!-- Storage Health View -->
            <ContentControl Content="{Binding StorageHealthViewModel}">
                <ContentControl.IsVisible>
                    <Binding Path="CurrentView">
                        <Binding.Converter>
                            <vm:EqualityConverter CompareValue="StorageHealth"/>
                        </Binding.Converter>
                    </Binding>
                </ContentControl.IsVisible>
                <ContentControl.ContentTemplate>
                    <DataTemplate x:DataType="vm:StorageHealthViewModel">
                        <views:StorageHealthView/>
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>

            <!-- Progress View -->
            <ContentControl Content="{Binding ProgressTab}">
                <ContentControl.IsVisible>
                    <Binding Path="CurrentView">
                        <Binding.Converter>
                            <vm:EqualityConverter CompareValue="Progress"/>
                        </Binding.Converter>
                    </Binding>
                </ContentControl.IsVisible>
                <ContentControl.ContentTemplate>
                    <DataTemplate x:DataType="vm:ProgressTabViewModel">
                        <views:ProgressView/>
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>

            <!-- Tier Migration View -->
            <ContentControl Content="{Binding TierMigrationViewModel}">
                <ContentControl.IsVisible>
                    <Binding Path="CurrentView">
                        <Binding.Converter>
                            <vm:EqualityConverter CompareValue="Migration"/>
                        </Binding.Converter>
                    </Binding>
                </ContentControl.IsVisible>
                <ContentControl.ContentTemplate>
                    <DataTemplate x:DataType="vm:TierMigrationViewModel">
                        <views:TierMigrationView/>
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" Padding="16,8">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="{Binding TotalFiles, StringFormat='Files: {0}'}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalSize, StringFormat='Size: {0}'}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

    <Window.Styles>
        <Style Selector="Button.nav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#40FFFFFF"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style Selector="Ellipse.pulse">
            <Style.Animations>
                <Animation Duration="0:0:1.5" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="CubicEaseInOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0.3"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1.0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Window.Styles>
</Window>
