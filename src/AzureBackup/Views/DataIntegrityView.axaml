<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AzureBackup.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="AzureBackup.Views.DataIntegrityView"
             x:DataType="vm:DataIntegrityViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" Classes="card" Margin="0,0,0,8">
            <StackPanel Orientation="Vertical" Spacing="4">
                <TextBlock Text="Data Integrity Check" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding StatusMessage}" Opacity="0.85" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Scope panel: dropdown + auto-export toggle + action buttons.
             Layout uses WrapPanel so buttons reflow onto a second row at
             >100% display scaling instead of clipping or overlapping
             siblings (D4 review fix 2.1/2.2/2.3). -->
        <Border Grid.Row="1" Classes="card" Margin="0,0,0,8">
            <StackPanel Orientation="Vertical" Spacing="6">
                <WrapPanel Orientation="Horizontal" ItemSpacing="8" LineSpacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="Scope:" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding ScopeOptions}"
                                  SelectedItem="{Binding SelectedScopePreset, Mode=TwoWay}"
                                  MinWidth="200"/>
                    </StackPanel>
                    <CheckBox Content="Auto-export bundle on failure"
                              IsChecked="{Binding AutoExportBundleOnFailure}"
                              ToolTip.Tip="When any failure occurs, automatically write a diagnostic bundle ZIP next to the data directory. Encrypted DB, salt, and other sensitive files are redacted from the bundle."
                              VerticalAlignment="Center"/>
                    <Button Content="_Check Now"
                            Command="{Binding CheckNowCommand}"/>
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            IsVisible="{Binding IsOperationInProgress}"/>
                    <Button Content="Re-check failures"
                            Command="{Binding ReCheckFailuresOfSelectedCommand}"
                            ToolTip.Tip="Run a focused integrity check against the failures of the selected History run (or the latest run if none selected). Same operation type; the new run records its lineage via ParentRunId."
                            IsVisible="{Binding HasFailures}"/>
                    <!-- D10: Backfill MD5 for chunks uploaded before D6 was
                         shipped. Hidden when there are no legacy chunks
                         (LegacyChunkCount == 0) to keep the toolbar clean. -->
                    <Button Content="{Binding BackfillButtonLabel}"
                            Command="{Binding BackfillLegacyMd5Command}"
                            ToolTip.Tip="Pre-D6 chunks have no upload-time MD5 stored. This scan downloads each one, verifies the envelope CRC and AES-GCM tag, and stamps the MD5 on success. Closes the trust-on-first-use window where a chunk corrupt before its first integrity check would have its corrupt MD5 captured as 'expected' and pass forever after."
                            IsVisible="{Binding HasBackfillWork}"/>
                </WrapPanel>
                <TextBlock Opacity="0.7" FontSize="12" TextWrapping="Wrap"
                           Text="{Binding SelectedFileCount, StringFormat='{}{0} file(s) selected. Choosing a preset auto-checks matching files; toggling files manually switches the dropdown to (Custom selection).'}"/>
            </StackPanel>
        </Border>

        <!-- File tree panel -->
        <Border Grid.Row="2" Classes="card" Margin="0,0,0,8">
            <Grid RowDefinitions="Auto,*">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                    <TextBlock Grid.Column="0" Text="Files in scope" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Refresh files" Command="{Binding RefreshFileTreeCommand}"
                            ToolTip.Tip="Re-read the backup catalogue. Use this after backing up new files in another tab so they appear here without restarting the app."/>
                </Grid>
                <TextBlock Grid.Row="1" IsVisible="{Binding !HasFiles}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Opacity="0.6" TextAlignment="Center"
                           Text="No backed-up files yet. Run a backup from the Sync tab first, then click Refresh files."/>
                <TreeView Grid.Row="1" IsVisible="{Binding HasFiles}"
                          ItemsSource="{Binding FileTreeRoots}">
                    <TreeView.ItemContainerTheme>
                        <ControlTheme TargetType="TreeViewItem"
                                      BasedOn="{StaticResource {x:Type TreeViewItem}}"
                                      x:DataType="vm:IntegrityFileTreeNodeViewModel">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        </ControlTheme>
                    </TreeView.ItemContainerTheme>
                    <TreeView.ItemTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <CheckBox IsChecked="{Binding IsSelected}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                           VerticalAlignment="Center"
                                           ToolTip.Tip="{Binding FullPath}"/>
                                <TextBlock Grid.Column="2" Text="{Binding FolderSummary}"
                                           Opacity="0.6" FontSize="11" Margin="8,0,0,0"
                                           IsVisible="{Binding IsFolder}" VerticalAlignment="Center"/>
                            </Grid>
                        </TreeDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>
        </Border>

        <!-- Progress strip -->
        <Border Grid.Row="3" Classes="card" Margin="0,0,0,8"
                IsVisible="{Binding IsOperationInProgress}">
            <StackPanel Orientation="Vertical" Spacing="4">
                <TextBlock Text="{Binding ProgressText}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="8"/>
                <TextBlock FontSize="11" Opacity="0.7">
                    <Run Text="T1 fail: "/><Run Text="{Binding T1FailCount}"/>
                    <Run Text="   T2 fail: "/><Run Text="{Binding T2FailCount}"/>
                    <Run Text="   T3 fail: "/><Run Text="{Binding T3FailCount}"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Result panel: failures + history expander -->
        <Border Grid.Row="4" Classes="card">
            <Grid RowDefinitions="Auto,*,Auto">
                <TextBlock Grid.Row="0" Text="Failures (latest run)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding FailureGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:IntegrityFailureGroupViewModel">
                                <Expander Header="{Binding Header}" IsExpanded="True" Margin="0,2">
                                    <!-- D9-A (post-D9-C pivot): Avalonia's commercial
                                         TreeDataGrid would have flattened groups + items
                                         into a single virtualized surface but requires
                                         a paid licence. Falling back to ListBox with the
                                         built-in VirtualizingStackPanel gives item-level
                                         virtualization (the dominant cost) while
                                         preserving the per-tier expander UX. Group count
                                         is bounded (T1/T2/T3/warn) so the outer
                                         ItemsControl is fine non-virtualized. -->
                                    <ListBox ItemsSource="{Binding Items}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             MaxHeight="600">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:IntegrityFailureItemViewModel">
                                                <Grid ColumnDefinitions="*,Auto,Auto" Margin="20,2,0,2">
                                                    <Grid.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Open .diag in default editor"
                                                                      Command="{Binding OpenDiagCommand}"
                                                                      IsEnabled="{Binding HasDiag}"/>
                                                            <MenuItem Header="Show .diag in folder"
                                                                      Command="{Binding ShowInFolderCommand}"
                                                                      IsEnabled="{Binding HasDiag}"/>
                                                        </ContextMenu>
                                                    </Grid.ContextMenu>
                                                    <StackPanel Grid.Column="0" Orientation="Vertical">
                                                        <TextBlock Text="{Binding DisplayPath}"
                                                                   ToolTip.Tip="{Binding DisplayPath}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock FontSize="11" Opacity="0.7">
                                                            <Run Text="{Binding Reason}"/>
                                                            <Run Text=" -- "/>
                                                            <Run Text="{Binding ChunkLabel}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding DiagPath}"
                                                               FontSize="10" Opacity="0.5" Margin="8,0"
                                                               ToolTip.Tip="Right-click to open or reveal in folder."
                                                               TextTrimming="CharacterEllipsis"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Expander Grid.Row="2" Header="History (last 10 runs -- click a row to view its failures)" Margin="0,8,0,0"
                          IsVisible="{Binding HasRunHistory}">
                    <ListBox ItemsSource="{Binding RunHistory}"
                             SelectedItem="{Binding SelectedRun, Mode=TwoWay}"
                             MaxHeight="320">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:IntegrityCheckRunViewModel">
                                <TextBlock Text="{Binding Header}" FontFamily="Consolas,monospace" FontSize="11"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Expander>
            </Grid>
        </Border>
    </Grid>
</UserControl>
