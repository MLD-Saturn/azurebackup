<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AzureBackup.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="800"
             x:Class="AzureBackup.Views.SettingsView"
             x:DataType="vm:MainWindowViewModel">

    <ScrollViewer>
        <StackPanel Spacing="16" MaxWidth="600">
            <!-- Authentication Method Selection -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="Authentication Method" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Choose how to connect to Azure Storage:" FontSize="12" Opacity="0.8"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <RadioButton GroupName="AuthMethod" 
                                     Content="Connection String (Personal Accounts)"
                                     IsChecked="{Binding UseConnectionString}"
                                     Command="{Binding SelectConnectionStringAuthCommand}"/>
                        <RadioButton GroupName="AuthMethod" 
                                     Content="Microsoft Entra ID (Work/School)"
                                     IsChecked="{Binding UseEntraId}"
                                     Command="{Binding SelectEntraIdAuthCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Connection String Authentication (for personal accounts) -->
            <Border Classes="card" IsVisible="{Binding UseConnectionString}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Azure Storage Connection" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Use this option with personal Microsoft accounts (@gmail.com, @outlook.com, etc.)" 
                               FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Connection String"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Text="{Binding ConnectionString}" 
                                     RevealPassword="{Binding ShowConnectionString}"
                                     PasswordChar="*" 
                                     Watermark="DefaultEndpointsProtocol=https;AccountName=..."/>
                            <ToggleButton Grid.Column="1" IsChecked="{Binding ShowConnectionString}" 
                                          Content="Show" ToolTip.Tip="Show/Hide" Margin="4,0,0,0"/>
                        </Grid>
                        <TextBlock Text="Find this in Azure Portal - Storage Account - Access keys" 
                                   FontSize="11" Opacity="0.6"/>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Container Name"/>
                        <TextBox Text="{Binding ContainerName}" Watermark="backup"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Test Connection" Command="{Binding TestConnectionCommand}"/>
                        <Button Content="Save &amp; Connect" Command="{Binding SaveStorageSettingsCommand}"
                                IsVisible="{Binding IsEditingConnectionString}"
                                ToolTip.Tip="Save the new connection string and reconnect"/>
                        <Button Content="Cancel" Command="{Binding CancelUpdateConnectionStringCommand}"
                                IsVisible="{Binding IsEditingConnectionString}"/>
                        <Button Content="Update Connection String" Command="{Binding UpdateConnectionStringCommand}"
                                IsVisible="{Binding CanUpdateConnectionString}"
                                ToolTip.Tip="Replace the stored connection string without losing any data"/>
                    </StackPanel>

                    <TextBlock Text="Your connection string will be encrypted before storage" 
                               FontSize="11" Foreground="Orange" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            
            <!-- Microsoft Entra ID Authentication (for work/school accounts) -->
            <Border Classes="card" IsVisible="{Binding UseEntraId}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Microsoft Account" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="Use this option with organizational accounts (work/school). Personal Microsoft accounts are NOT supported." 
                               FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                    
                    <StackPanel Spacing="8">
                        <TextBlock Text="{Binding EntraIdStatus}" FontWeight="SemiBold"
                                   Foreground="{Binding IsEntraIdAuthenticated, Converter={StaticResource BoolToColorConverter}}"/>
                        
                        <!-- Sign in button (visible when not authenticated and not signing in) -->
                        <Button Content="Sign in with Microsoft" 
                                Command="{Binding SignInWithEntraIdCommand}"
                                IsVisible="{Binding !IsEntraIdAuthenticated}"
                                IsEnabled="{Binding !IsOperationInProgress}"
                                Classes="primary"/>
                        
                        <!-- Cancel button (visible during sign-in) -->
                        <StackPanel Orientation="Horizontal" Spacing="8" 
                                    IsVisible="{Binding IsOperationInProgress}">
                            <ProgressBar IsIndeterminate="True" Width="100" Height="8"/>
                            <Button Content="Cancel" Command="{Binding CancelSignInCommand}"/>
                        </StackPanel>
                        
                        <TextBlock IsVisible="{Binding IsEntraIdAuthenticated}" 
                                   Text="Authenticated with Microsoft Entra ID" 
                                   Foreground="LightGreen" FontSize="12"/>
                        
                        <TextBlock Text="Clicking 'Sign in' will open your browser. You have 2 minutes to complete sign-in." 
                                   FontSize="11" Opacity="0.6" TextWrapping="Wrap"
                                   IsVisible="{Binding !IsEntraIdAuthenticated}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <!-- Azure Storage Configuration (for Entra ID) -->
            <Border Classes="card" IsVisible="{Binding UseEntraId}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Azure Storage" FontSize="18" FontWeight="SemiBold"/>
                    
                    <StackPanel Spacing="4">
                        <TextBlock Text="Storage Account Name"/>
                        <TextBox Text="{Binding StorageAccountName}" 
                                 Watermark="e.g., mystorageaccount"/>
                        <TextBlock Text="Enter just the account name, not the full URL" 
                                   FontSize="11" Opacity="0.6"/>
                    </StackPanel>
                    
                    <StackPanel Spacing="4">
                        <TextBlock Text="Container Name"/>
                        <TextBox Text="{Binding ContainerName}" Watermark="backup"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Test Connection" Command="{Binding TestConnectionCommand}"/>
                    </StackPanel>
                    
                    <TextBlock Text="Ensure you have 'Storage Blob Data Contributor' role on this storage account" 
                               FontSize="11" Foreground="Orange" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding PasswordSectionTitle}" FontSize="18" FontWeight="SemiBold"/>
                    
                    <!-- Returning user: just enter password -->
                    <StackPanel Spacing="4" IsVisible="{Binding HasExistingConfig}">
                        <TextBlock Text="Enter your password to unlock encryption"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Text="{Binding Password}" 
                                     RevealPassword="{Binding ShowPassword}"
                                     PasswordChar="*" Watermark="Enter your password"/>
                            <ToggleButton Grid.Column="1" IsChecked="{Binding ShowPassword}" 
                                          Content="Show" ToolTip.Tip="Show/Hide" Margin="4,0,0,0"/>
                        </Grid>
                    </StackPanel>
                    
                    <!-- New user: password + confirmation -->
                    <StackPanel Spacing="4" IsVisible="{Binding IsNewUser}">
                        <TextBlock Text="Password (used to derive encryption key)"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Text="{Binding Password}" 
                                     RevealPassword="{Binding ShowPassword}"
                                     PasswordChar="*" Watermark="Enter a strong password"/>
                            <ToggleButton Grid.Column="1" IsChecked="{Binding ShowPassword}" 
                                          Content="Show" ToolTip.Tip="Show/Hide" Margin="4,0,0,0"/>
                        </Grid>
                    </StackPanel>
                    
                    <StackPanel Spacing="4" IsVisible="{Binding IsNewUser}">
                        <TextBlock Text="Confirm Password"/>
                        <TextBox Text="{Binding PasswordConfirm}" 
                                 RevealPassword="{Binding ShowPassword}"
                                 PasswordChar="*" Watermark="Re-enter password"/>
                        <TextBlock Text="Passwords do not match!" FontSize="12" Foreground="Red"
                                   IsVisible="{Binding PasswordMismatch}"/>
                    </StackPanel>
                    
                    <TextBlock Text="If you forget this password, your data cannot be recovered!" 
                               FontSize="12" Foreground="Orange" IsVisible="{Binding IsNewUser}"/>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Watched Folders" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="(Add/remove folders in the Sync tab)" FontSize="12" Opacity="0.6" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <ListBox ItemsSource="{Binding WatchedFolders}" SelectedItem="{Binding SelectedWatchedFolder}"
                             MinHeight="100" MaxHeight="200">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:WatchedFolderViewModel">
                                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" Margin="4">
                                    <CheckBox IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"
                                              ToolTip.Tip="Enable/disable this folder"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Path}" VerticalAlignment="Center" 
                                               Margin="8,0" FontWeight="SemiBold"/>
                                    <Border Grid.Column="2" Background="{DynamicResource AppAccentLight3Brush}"
                                             CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StorageTier}" FontSize="11" Opacity="0.9"/>
                                    </Border>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="8,2,0,0"
                                               FontSize="11" Opacity="0.6">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="Exclude: {0}">
                                                <Binding Path="ExcludePatterns"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <!-- Folder configuration section - always visible with guidance -->
                    <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" 
                            CornerRadius="4" Padding="12" Margin="0,8,0,0">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Folder Settings" FontWeight="SemiBold"/>
                            
                            <StackPanel IsVisible="{Binding SelectedWatchedFolder, Converter={x:Static ObjectConverters.IsNull}}">
                                <TextBlock Text="Select a folder above to configure settings" 
                                           Opacity="0.6" FontStyle="Italic"/>
                            </StackPanel>
                            
                            <StackPanel Spacing="8" IsVisible="{Binding SelectedWatchedFolder, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <TextBlock Text="{Binding SelectedWatchedFolder.Path}" FontWeight="SemiBold" 
                                           TextTrimming="CharacterEllipsis"/>
                                
                                <!-- Storage Tier Selection -->
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Storage Tier" FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding SelectedWatchedFolder.StorageTierOptions}"
                                              SelectedItem="{Binding SelectedWatchedFolder.StorageTier}"
                                              HorizontalAlignment="Left" MinWidth="120"/>
                                    <TextBlock FontSize="11" Opacity="0.5" TextWrapping="Wrap">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}Hot = frequent access, Cool = infrequent (default), Cold = rare access">
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                                
                                <!-- Exclusion Patterns -->
                                <StackPanel Spacing="4" Margin="0,8,0,0">
                                    <TextBlock Text="Exclusion Patterns" FontSize="12"/>
                                    <TextBlock Text="Exclude files/folders matching these patterns (semicolon separated):" 
                                               FontSize="11" Opacity="0.7"/>
                                    <TextBox Text="{Binding SelectedWatchedFolder.ExcludePatterns}"
                                             Watermark="e.g., *.tmp;*.log;node_modules;.git;bin;obj"/>
                                    <TextBlock Text="Common patterns: *.log, *.tmp, *.bak, thumbs.db, .git, node_modules, bin, obj, .vs" 
                                               FontSize="11" Opacity="0.5" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <!-- Unified unlock/initialize and connect button -->
                <Button Command="{Binding UnlockAndConnectCommand}" Classes="primary"
                        IsEnabled="{Binding !IsInitialized}"
                        ToolTip.Tip="Unlock encryption and connect to Azure Storage">
                    <TextBlock Text="{Binding UnlockAndConnectButtonText}"/>
                </Button>
                <TextBlock Text="[OK] Unlocked and Connected" Foreground="LimeGreen" FontWeight="SemiBold" 
                           VerticalAlignment="Center" IsVisible="{Binding IsInitialized}"/>
            </StackPanel>

            <!-- Reset Application Section -->
            <Border Classes="card" Margin="0,24,0,0" BorderBrush="IndianRed" BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Danger Zone" FontSize="16" FontWeight="SemiBold" Foreground="IndianRed"/>
                    <TextBlock Text="Reset the application to start fresh. This will securely delete all local settings, credentials, and file tracking data. Your files in Azure Storage will NOT be affected."
                               TextWrapping="Wrap" Opacity="0.8"/>
                    
                    <!-- Normal state: Show reset button -->
                    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding !IsResetPending}">
                        <Button Content="Reset Application..." Command="{Binding RequestResetCommand}"
                                Foreground="IndianRed"
                                ToolTip.Tip="Securely delete all settings and start fresh"/>
                    </StackPanel>
                    
                    <!-- Confirmation state: Show confirm/cancel -->
                    <StackPanel IsVisible="{Binding IsResetPending}" Spacing="8">
                        <TextBlock Text="Are you sure? This action cannot be undone!" 
                                   Foreground="Orange" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Cancel" Command="{Binding CancelResetCommand}"/>
                            <Button Content="Confirm Reset" Command="{Binding ConfirmResetCommand}"
                                    Background="IndianRed" Foreground="White"
                                    ToolTip.Tip="Permanently delete all settings and data"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
